    "def find_best_match_index(query_embedding, embeddings):\n",
    "    scores = [np.dot(query_embedding, emb) for emb in embeddings]\n",
    "    best_idx = np.argmax(scores)\n",
    "    return best_idx, scores[best_idx]"
   ]
